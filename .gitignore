# =============================================================================
# Unreal Engine 5 — .gitignore
# =============================================================================

# ----- Build outputs (auto-generated, never track) --------------------------
Binaries/
Build/
Intermediate/
DerivedDataCache/

# ----- Editor / runtime state -----------------------------------------------
Saved/
.vs/
*.VC.db
*.VC.opendb
*.opensdf
*.sdf

# ----- Auto-generated Visual Studio solution / project files ----------------
# UBT regenerates these; tracking them causes constant noise
*.sln
*.csproj

# ----- Auto-generated makefile / XCode files --------------------------------
*.xcworkspace
*.xcodeproj

# ----- Log & crash files ----------------------------------------------------
*.log

# ----- OS noise files -------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# ----- Python cache (Editor Scripting / automation) -------------------------
__pycache__/
*.py[cod]
*.pyo

# ----- Plugin intermediates (each plugin has its own Binaries/Intermediate) -
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ----- Pak / cooked content (output of cook / package pipeline) -------------
# Never commit cooked or packaged builds; they are reproducible from source
*.pak
*.ucas
*.utoc
*.uassetmanifest

# ----- Crash / debug symbols ------------------------------------------------
*.pdb
*.map

# ----- Clang / compile_commands (generated by rider/vscode tooling) ---------
compile_commands.json
.cache/

# ----- JetBrains Rider -------------------------------------------------------
.idea/

# ----- VS Code ---------------------------------------------------------------
.vscode/

# ----- IncrediBuild / Fastbuild ----------------------------------------------
*.bff.log
